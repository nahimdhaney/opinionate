{
  "name": "opinionate",
  "version": "0.2.0",
  "description": "Structured peer deliberation and Codex-backed second opinions for AI coding tools.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "opinionate": "./dist/src/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nahimdhaney/opinionate.git"
  },
  "homepage": "https://github.com/nahimdhaney/opinionate",
  "bugs": {
    "url": "https://github.com/nahimdhaney/opinionate/issues"
  },
  "author": "Nahim Dhaney",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:packaging": "node scripts/check-package-artifact.mjs",
    "install-skill": "node dist/src/cli.js install",
    "prepublishOnly": "pnpm build && pnpm test && pnpm run test:packaging"
  },
  "keywords": [
    "ai",
    "agent",
    "deliberation",
    "codex",
    "claude",
    "peer-review",
    "planning",
    "code-review",
    "diagnostics",
    "trace"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "skill"
  ],
  "dependencies": {
    "@clack/prompts": "^1.1.0"
  }
}
